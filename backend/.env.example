# App
APP_ENV=development
DATABASE_URL=sqlite:///./meeting_assistant.db
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ASR Provider
# 主路径为 custom：向 ASR_API_BASE_URL 发起 multipart/form-data 请求。
ASR_PROVIDER=custom
ASR_API_KEY=
ASR_API_BASE_URL=
ASR_MODEL=custom-asr
ASR_ENABLE_SPEAKER_DIARIZATION=true

# LLM Provider
# OpenAI-compatible: POST {LLM_API_BASE_URL}/chat/completions
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_API_BASE_URL=
LLM_MODEL=deepseek-chat

# Embedding Provider
# OpenAI-compatible: POST {EMBEDDING_API_BASE_URL}/embeddings
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# Request
AI_REQUEST_TIMEOUT=60
